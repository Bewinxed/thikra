// ==================== PERSONALITY MONITORING (PERSDYN MODEL) ====================

model PersonalityObservation {
  id               String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  personaId        String   @db.Uuid
  traitDimension   String   @db.VarChar(100) // e.g., "openness", "emotional_intensity"
  observedValue    Float    // Continuous value in trait space
  
  // Context fields (no JSON!)
  situation             String?  @db.Text // What situation prompted this expression
  interactionPartnerId  String?  @db.Uuid // Who they were interacting with
  emotionalStateId      String?  @db.Uuid // Current emotional state
  trigger               String?  @db.Text // What triggered this personality expression
  
  sourceMemoryId   String?  @db.Uuid
  confidence       Float    @default(0.5) // 0-1 confidence in observation
  observedAt       DateTime @default(now())
  
  // Relations
  persona             Persona         @relation(fields: [personaId], references: [id], onDelete: Cascade)
  sourceMemory        Memory?         @relation(fields: [sourceMemoryId], references: [id])
  interactionPartner  Entity?         @relation(fields: [interactionPartnerId], references: [id])
  emotionalState      EmotionalState? @relation(fields: [emotionalStateId], references: [id])
  evidence            PersonalityObservationEvidence[]
  
  @@index([personaId, traitDimension, observedAt])
  @@index([personaId, situation])
  @@index([personaId, interactionPartnerId])
}

// Evidence supporting personality observations
model PersonalityObservationEvidence {
  id            String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  observationId String   @db.Uuid
  evidence      String   @db.Text // Direct quote or behavior
  evidenceType  String   @db.VarChar(50) // "quote", "behavior", "reaction", etc.
  
  // Relations
  observation PersonalityObservation @relation(fields: [observationId], references: [id], onDelete: Cascade)
  
  @@index([observationId])
}

model PersonalityParameter {
  id               String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  personaId        String   @db.Uuid
  traitDimension   String   @db.VarChar(100)
  
  // PersDyn three-parameter model
  baseline         Float    // μ: Long-term stable center
  variability      Float    // σ: Natural fluctuation range  
  attractorForce   Float    // θ: Pull back to baseline strength
  
  // Uncertainty bounds (Bayesian)
  baselineUncertainty      Float @default(1.0)
  variabilityUncertainty   Float @default(1.0)
  attractorUncertainty     Float @default(1.0)
  
  // Metadata
  observationCount Int      @default(0)
  lastUpdated      DateTime @default(now())
  
  // Relations
  persona          Persona                      @relation(fields: [personaId], references: [id], onDelete: Cascade)
  parameterHistory PersonalityParameterHistory[]
  
  @@unique([personaId, traitDimension])
  @@index([personaId])
}

// Track personality parameter evolution using PersDyn model
// Ref: docs/persdyn-model-reference.md
model PersonalityParameterHistory {
  id            String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  parameterId   String   @db.Uuid
  
  // Historical parameter values
  baseline      Float
  variability   Float
  attractorForce Float
  
  // What triggered this update
  triggerType   String   @db.VarChar(50) // "new_observations", "drift_detected", etc.
  
  // Drift details (instead of JSON)
  baselineDrift      Float? // How much baseline changed
  variabilityDrift   Float? // How much variability changed  
  attractorDrift     Float? // How much attractor force changed
  driftSignificance  Float? // Overall significance score
  
  recordedAt    DateTime @default(now())
  
  // Relations
  parameter PersonalityParameter @relation(fields: [parameterId], references: [id], onDelete: Cascade)
  
  @@index([parameterId, recordedAt])
}
