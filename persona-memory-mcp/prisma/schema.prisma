}

// ==================== DYNAMIC STATE SYSTEM (KV STORE) ====================
// States are discovered and tracked dynamically as LLMs reference them

model PersonaState {
  id            String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  personaId     String   @db.Uuid
  stateKey      String   @db.VarChar(100) // e.g., "heat_level", "arousal"
  stateValue    Json     @db.JsonB // Flexible value storage
  valueType     String   @db.VarChar(50) // counter, boolean, timer, object
  description   String?  @db.Text
  createdAt     DateTime @default(now())
  lastUpdated   DateTime @default(now()) @updatedAt
  updateCount   Int      @default(0)
  isConsciousOf Boolean  @default(true) // Is persona aware of this state?

  // Relations
  persona      Persona              @relation(fields: [personaId], references: [id], onDelete: Cascade)
  stateChanges PersonaStateChange[]

  @@unique([personaId, stateKey])
  @@index([personaId, stateKey])
  @@index([lastUpdated(sort: Desc)])
}

model PersonaStateChange {
  id              String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  stateId         String   @db.Uuid
  oldValue        Json?    @db.JsonB
  newValue        Json?    @db.JsonB
  changedAt       DateTime @default(now())
  triggerType     String   @db.VarChar(50) // manual, memory, conversation
  triggerDetails  Json?    @db.JsonB
  relatedMemoryId String?  @db.Uuid

  // Relations
  state         PersonaState @relation(fields: [stateId], references: [id], onDelete: Cascade)
  relatedMemory Memory?      @relation(fields: [relatedMemoryId], references: [id])

}

